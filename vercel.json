{
  "buildCommand": "cd frontend && rm -rf node_modules .next && npm install --legacy-peer-deps && npm run build",
  "installCommand": "cd frontend && rm -rf node_modules package-lock.json && npm install --legacy-peer-deps",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "https://flume-api.onrender.com"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
